# --- Application ---
APP_NAME=NitiNova
APP_VERSION=1.0.0
APP_ENV=development
API_PREFIX=/api
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info
FRONTEND_URL=http://localhost:3000
CORS_ALLOW_ORIGINS=http://localhost:3000

# --- Authentication / Security ---
SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Database (PostgreSQL) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=niti_nova
POSTGRES_USER=niti_nova
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Cache / Rate Limiting ---
REDIS_URL=redis://localhost:6379/0

# --- Vector Store ---
VECTOR_STORE_PROVIDER=pinecone
PINECONE_API_KEY=your-pinecone-key
PINECONE_ENVIRONMENT=us-east1-gcp
PINECONE_INDEX_NAME=niti-nova
FAISS_INDEX_PATH=data/processed/faiss.index

# --- LLM Providers ---
OPENAI_API_KEY=your-openai-key
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1
ANTHROPIC_API_KEY=your-anthropic-key
ANTHROPIC_MODEL=claude-3-opus-20240229
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# --- Embeddings ---
EMBEDDING_MODEL=text-embedding-3-large

# --- Feature Flags ---
ENABLE_RAG=true
ENABLE_VERIFICATION=true

# --- Commercial / COTS metadata ---
PRODUCT_EDITION=community
SUPPORT_EMAIL=support@nitinova.ai
DOCS_URL=https://docs.nitinova.ai
SLA_TIER=standard
